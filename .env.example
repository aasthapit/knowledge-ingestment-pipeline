# ── Embedding Model ──────────────────────────────────────────────────────────
# Provider: openai | azure | sentence-transformers
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# Dimensions produced by text-embedding-3-small = 1536
# Dimensions produced by text-embedding-3-large = 3072
EMBEDDING_DIMENSIONS=1536

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Azure OpenAI (only needed when EMBEDDING_PROVIDER=azure) ─────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# ── Redis Enterprise ──────────────────────────────────────────────────────────
# Format: redis://[[username]:[password]]@host:port
REDIS_URL=redis://localhost:6379
REDIS_INDEX_NAME=knowledge_index
REDIS_KEY_PREFIX=doc:

# ── Pipeline Settings ─────────────────────────────────────────────────────────
# Maximum characters per chunk (applied after heading splits)
CHUNK_MAX_CHARS=2000
# Overlap in characters between consecutive chunks within the same section
CHUNK_OVERLAP_CHARS=200
# Batch size for embedding API calls
EMBED_BATCH_SIZE=32

# ── JSONL Export ──────────────────────────────────────────────────────────────
JSONL_OUTPUT_DIR=./output
